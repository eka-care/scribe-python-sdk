# Copy to .env (auto-loaded). Env vars override the config file.

# Environment: "prod" (api.eka.care, default) or "dev" (api.dev.eka.care).
SCRIBE_ENV=prod
# Optional: override the hosts directly (these win over SCRIBE_ENV).
# SCRIBE_BASE_URL=https://api.eka.care/voice
# SCRIBE_AUTH_BASE_URL=https://api.eka.care
SCRIBE_CLIENT_ID=your-client-id
SCRIBE_CLIENT_SECRET=your-client-secret
SCRIBE_DEFAULT_TEMPLATES=eka_emr_template,clinical_notes_template
SCRIBE_DEFAULT_MODEL=pro
